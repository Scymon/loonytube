# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only. Used by the Stream webhook to bypass RLS. NEVER expose to client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Cloudflare Stream ----
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_STREAM_API_TOKEN=your-stream-api-token
# Your Stream customer subdomain code (the xxxx in customer-xxxx.cloudflarestream.com).
# Found on any video's embed/HLS URL in the Cloudflare dashboard.
NEXT_PUBLIC_CLOUDFLARE_STREAM_CODE=your-customer-code
